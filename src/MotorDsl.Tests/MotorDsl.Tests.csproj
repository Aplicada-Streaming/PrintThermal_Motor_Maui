<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<Using Include="Xunit" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\MotorDsl.Core\MotorDsl.Core.csproj" />
		<ProjectReference Include="..\MotorDsl.Extensions\MotorDsl.Extensions.csproj" />
		<ProjectReference Include="..\MotorDsl.Parser\MotorDsl.Parser.csproj" />
		<ProjectReference Include="..\MotorDsl.Rendering\MotorDsl.Rendering.csproj" />
		<ProjectReference Include="..\MotorDsl.Printing.Abstractions\MotorDsl.Printing.Abstractions.csproj" />
	</ItemGroup>

	<!--
		ChunkBuffer y ClassifyStatusResponse son codigo puro de MotorDsl.Bluetooth, pero ese
		proyecto solo targetea net10.0-android/net10.0-ios y no puede referenciarse desde este
		net10.0. Se enlazan por fuente solo los archivos partial puros (sin dependencias de
		plataforma) para cubrirlos con tests sin contaminar el paquete NuGet con un target net10.0.
	-->
	<ItemGroup>
		<Compile Include="..\MotorDsl.Bluetooth\BluetoothPrinterTransport.Chunking.cs" Link="Linked\BluetoothPrinterTransport.Chunking.cs" />
		<Compile Include="..\MotorDsl.Bluetooth\BluetoothPrinterTransport.Capabilities.cs" Link="Linked\BluetoothPrinterTransport.Capabilities.cs" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="coverlet.collector" Version="6.0.4" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.8" />
		<PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
		<PackageReference Include="xunit" Version="2.9.3" />
		<PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
	</ItemGroup>

</Project>